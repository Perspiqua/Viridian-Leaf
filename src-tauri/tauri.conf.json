{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Viridian Leaf",
  "version": "1.2.0",
  "identifier": "uk.viridian-intelligence.viridian-leaf",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Viridian Leaf",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob:; connect-src 'self' https://huggingface.co https://*.huggingface.co https://cdn-lfs.huggingface.co https://cdn-lfs-us-1.huggingface.co https://cdn-lfs.hf.co https://*.xethub.hf.co https://unpkg.com https://cdnjs.cloudflare.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' blob:; worker-src 'self' blob:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "timestampUrl": null,
      "wix": null,
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      }
    },
    "fileAssociations": [
      {
        "ext": ["pdf"],
        "name": "PDF Document",
        "description": "PDF Document",
        "role": "Viewer"
      }
    ],
    "publisher": "Viridian Intelligence Ltd. UK",
    "copyright": "Copyright (c) 2026 Viridian Intelligence Ltd. UK",
    "category": "Utility",
    "shortDescription": "A free, lightweight PDF viewer and editor",
    "longDescription": "Viridian Leaf is a free, open-source PDF viewer and editor. No bloatware. No subscriptions. Just PDFs.",
    "licenseFile": "../LICENSE"
  }
}
